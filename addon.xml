<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.flowplay" 
       name="Flow Play" 
       version="1.0.0" 
       provider-name="Jarko">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="plugin.video.youtube" version="6.8.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="sk">Streamovací portál Flow Play</summary>
        <description lang="sk">Oficiálny doplnok Flow Play pre sledovanie relácií, filmov a obsahu pre deti.</description>
        <disclaimer lang="sk">Obsah je poskytovaný prostredníctvom verejne dostupných zdrojov.</disclaimer>
        <language>sk</language>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
